# Cred Rank Net — production environment template
# Copy to .env.production and fill in real values before deployment.
#
#   cp .env.production.example .env.production
#   chmod 600 .env.production

# --- Required (startup fails if missing) ---
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
DATABASE_URL=file:/data/db.sqlite
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-token

# --- Required for auth & uploads ---
NEXTAUTH_URL=https://crn.anikait.page
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret
UPLOADTHING_TOKEN=replace-with-uploadthing-token

# --- Optional ---
ADMIN_EMAILS=admin@yourdomain.com

# --- Docker Compose (host port binding, localhost only) ---
CREDRANKNET_PORT=3010

# --- Runtime ---
NODE_ENV=production

# Trust forwarded headers from Nginx reverse proxy (NextAuth)
AUTH_TRUST_HOST=true
